            <path d="M 0,-285 L -3,-260 L 4,-235 L -2,-210 L 5,-185" stroke="var(--crimson)" stroke-width="1.4" fill="none" filter="url(#crimsonGlow)" opacity="0.75"/>
            <path d="M 0,-285 L -3,-260 L 4,-235 L -2,-210 L 5,-185" stroke="var(--crimson)" stroke-width="0.7" fill="none" opacity="0.95"/>
          </g>
          <g class="crack" transform="rotate(155)">
            <path d="M 0,-285 L 2,-258 L -4,-232 L 3,-208 L -2,-180" stroke="var(--crimson)" stroke-width="1.4" fill="none" filter="url(#crimsonGlow)" opacity="0.75"/>
            <path d="M 0,-285 L 2,-258 L -4,-232 L 3,-208 L -2,-180" stroke="var(--crimson)" stroke-width="0.7" fill="none" opacity="0.95"/>
          </g>
          <g class="crack" transform="rotate(265)">
            <path d="M 0,-285 L -2,-262 L 3,-238 L -3,-214 L 4,-188" stroke="var(--crimson)" stroke-width="1.4" fill="none" filter="url(#crimsonGlow)" opacity="0.75"/>
            <path d="M 0,-285 L -2,-262 L 3,-238 L -3,-214 L 4,-188" stroke="var(--crimson)" stroke-width="0.7" fill="none" opacity="0.95"/>
