        <!-- Tear gradient is now green leak -->
        <linearGradient id="tearGrad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#7FD4B5" stop-opacity="1"/>
          <stop offset="40%" stop-color="#4FA88A" stop-opacity="0.95"/>
