<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>The Codex Sigil — Preview v3</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Cinzel:wght@400;500&family=Crimson+Text:ital,wght@0,400;1,400&family=Share+Tech+Mono&display=swap" rel="stylesheet">

<style>
  :root{
    --void:#05050A;
    --void-2:#0A0A12;
    --crimson:#7A1212;
    --crimson-dim:#4A0808;
    --gold:#C9A84C;
    --gold-lt:#E0C878;
    --gold-deep:#8A7330;
    --ash:#E4DDD0;
    /* Realm III contamination — the leak */
    --leak:#4FA88A;
    --leak-lt:#7FD4B5;
    --leak-deep:#1F5544;
    --leak-glow:#5FBA98;
  }

  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  html,body{height:100%;background:var(--void);color:var(--ash);font-family:'Crimson Text',serif;overflow-x:hidden}

  body{
    position:relative;
    min-height:100vh;
    background:
      radial-gradient(ellipse at 50% 35%, rgba(79,168,138,0.08) 0%, transparent 55%),
      radial-gradient(ellipse at 50% 100%, rgba(201,168,76,0.04) 0%, transparent 60%),
      var(--void);
    overflow:hidden;
  }

  body::before{
    content:'';
    position:fixed;
    inset:0;
    pointer-events:none;
    z-index:1;
    opacity:0.06;
    mix-blend-mode:overlay;
    background-image:url("data:image/svg+xml;utf8,<svg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3'/></filter><rect width='100%25' height='100%25' filter='url(%23n)' opacity='0.7'/></svg>");
  }

  body::after{
    content:'';
    position:fixed;
    inset:0;
    pointer-events:none;
    z-index:0;
    opacity:0.025;
    background-image:
      linear-gradient(60deg, transparent 49.5%, var(--gold) 49.5%, var(--gold) 50.5%, transparent 50.5%),
      linear-gradient(-60deg, transparent 49.5%, var(--gold) 49.5%, var(--gold) 50.5%, transparent 50.5%),
      linear-gradient(0deg, transparent 49.5%, var(--gold) 49.5%, var(--gold) 50.5%, transparent 50.5%);
    background-size:46px 80px;
  }

  .frame{
    position:relative;
    z-index:2;
    min-height:100vh;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    padding:40px 20px 80px;
  }

  .preview-meta{
    position:fixed;
    top:16px;
    left:16px;
    font-family:'Share Tech Mono',monospace;
    font-size:10px;
    letter-spacing:0.15em;
    color:var(--gold-deep);
    opacity:0.6;
    z-index:10;
  }
  .preview-meta span{display:block;line-height:1.6}

  .preview-controls{
    position:fixed;
    top:16px;
    right:16px;
    display:flex;
    flex-direction:column;
    gap:8px;
    z-index:10;
    font-family:'Share Tech Mono',monospace;
    font-size:10px;
    letter-spacing:0.1em;
  }
  .preview-controls button{
    background:rgba(5,5,10,0.7);
    border:1px solid rgba(201,168,76,0.35);
    color:var(--gold);
    padding:6px 10px;
    cursor:pointer;
    font-family:inherit;
    font-size:inherit;
    letter-spacing:inherit;
    transition:all .25s ease;
  }
  .preview-controls button:hover{
    background:rgba(201,168,76,0.1);
    border-color:var(--gold);
    color:var(--gold-lt);
  }

  .sigil-vessel{
    position:relative;
    width:min(600px, 94vw);
    aspect-ratio:1/1;
    display:flex;
    align-items:center;
    justify-content:center;
  }

  /* Dual glow behind sigil — crimson outer, green inner from the leak */
  .sigil-vessel::before{
    content:'';
    position:absolute;
    inset:6%;
    border-radius:50%;
    background:
      radial-gradient(circle at center, rgba(79,168,138,0.22) 0%, rgba(79,168,138,0.08) 22%, transparent 42%),
      radial-gradient(circle, rgba(122,18,18,0.18) 38%, transparent 68%);
    filter:blur(18px);
    z-index:0;
    animation:breathe 8s ease-in-out infinite;
  }

  @keyframes breathe{
    0%,100%{opacity:0.85;transform:scale(1)}
    50%{opacity:1;transform:scale(1.04)}
  }

  #codex-sigil{
    position:relative;
    z-index:2;
    width:100%;
    height:100%;
    display:block;
    filter:drop-shadow(0 0 28px rgba(79,168,138,0.18)) drop-shadow(0 0 12px rgba(201,168,76,0.16));
  }

  .tear-field{
    position:absolute;
    inset:0;
    pointer-events:none;
    z-index:3;
    overflow:visible;
  }

  /* Tears are now green — Realm III contamination running down */
  .page-tear{
    position:absolute;
    width:3.5px;
    border-radius:2px;
    background:linear-gradient(to bottom, var(--leak-lt) 0%, var(--leak) 35%, rgba(79,168,138,0.5) 75%, transparent 100%);
    box-shadow:0 0 6px rgba(127,212,181,0.7), 0 0 14px rgba(79,168,138,0.4);
    transform-origin:top center;
    animation:tearFall var(--dur,4s) linear forwards;
  }

  @keyframes tearFall{
    0%{height:0;opacity:0}
    6%{height:10px;opacity:1}
    88%{opacity:0.75}
    100%{height:var(--len,200px);opacity:0;transform:translateY(var(--y,220px))}
  }

  .caption{
    margin-top:36px;
    text-align:center;
    max-width:560px;
    z-index:2;
    position:relative;
  }
  .caption .designation{
    font-family:'Share Tech Mono',monospace;
    font-size:10px;
    letter-spacing:0.35em;
    color:var(--gold-deep);
    opacity:0.75;
    margin-bottom:10px;
  }
  .caption h1{
    font-family:'Cinzel Decorative',serif;
    font-weight:700;
    font-size:clamp(20px, 3.2vw, 30px);
    color:var(--gold);
    letter-spacing:0.18em;
    margin-bottom:14px;
    text-shadow:0 0 24px rgba(201,168,76,0.25);
  }
  .caption p{
    font-family:'Crimson Text',serif;
    font-style:italic;
    font-size:clamp(13px, 1.8vw, 15px);
    line-height:1.7;
    color:rgba(228,221,208,0.65);
    letter-spacing:0.02em;
  }
  .caption .attribution{
    margin-top:16px;
    font-family:'Cinzel',serif;
    font-size:10px;
    letter-spacing:0.3em;
    color:var(--gold-deep);
    text-transform:uppercase;
  }

  .lock-pulse{
    position:fixed;
    bottom:16px;
    left:50%;
    transform:translateX(-50%);
    font-family:'Share Tech Mono',monospace;
    font-size:9px;
    letter-spacing:0.3em;
    color:var(--gold-deep);
    opacity:0;
    transition:opacity .3s ease;
    z-index:10;
    pointer-events:none;
  }
  .lock-pulse.active{opacity:0.85}

  body{cursor:none}
  .codex-cursor{
    position:fixed;
    width:24px;
    height:24px;
    pointer-events:none;
    z-index:9999;
    transform:translate(-50%,-50%);
    mix-blend-mode:difference;
  }
  .codex-cursor svg{width:100%;height:100%}
  .codex-cursor circle{fill:none;stroke:var(--gold-lt);stroke-width:1}
  .codex-cursor line{stroke:var(--gold-lt);stroke-width:1}

  @media (max-width:520px){
    body{cursor:auto}
    .codex-cursor{display:none}
    .preview-meta{font-size:9px}
    .preview-controls{font-size:9px}
  }

  @media (prefers-reduced-motion:reduce){
    *{animation-duration:0.001s !important; animation-iteration-count:1 !important}
  }
</style>
</head>
<body>

<div class="preview-meta">
  <span>IDMF // FORENSIC PREVIEW v3</span>
  <span id="visit-state">VISITOR_STATE: FIRST_CONTACT</span>
  <span id="lock-counter">LOCK_BEATS: 0</span>
</div>

<div class="preview-controls">
