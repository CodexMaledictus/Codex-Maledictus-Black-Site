/* THE THIRTEEN VOICES */
const VOICES = [
  {id:'rot', name:'Omniscient Rot', glyph:'⛧', state:'claimed', angle:0},
  {id:'artemys', name:'Forgotten Saint Artemys', glyph:'☩', state:'claimed', angle:360/13 * 5},
  {id:'gavinci', name:'Apollo Gavinci', glyph:'☉', state:'claimed', angle:360/13 * 9},
  {id:'voice-04', name:'[REDACTED]', glyph:'·', state:'sleeping', angle:360/13 * 1},
  {id:'voice-05', name:'[REDACTED]', glyph:'·', state:'sleeping', angle:360/13 * 2},
  {id:'voice-06', name:'[REDACTED]', glyph:'·', state:'sleeping', angle:360/13 * 3},
  {id:'voice-07', name:'[REDACTED]', glyph:'·', state:'sleeping', angle:360/13 * 4},
  {id:'voice-08', name:'[REDACTED]', glyph:'·', state:'sleeping', angle:360/13 * 6},
  {id:'voice-09', name:'[REDACTED]', glyph:'·', state:'sleeping', angle:360/13 * 7},
  {id:'voice-10', name:'[REDACTED]', glyph:'·', state:'sleeping', angle:360/13 * 8},
  {id:'voice-11', name:'[REDACTED]', glyph:'·', state:'sleeping', angle:360/13 * 10},
  {id:'voice-12', name:'[REDACTED]', glyph:'·', state:'sleeping', angle:360/13 * 11},
  {id:'voice-13', name:'[REDACTED]', glyph:'·', state:'sleeping', angle:360/13 * 12}
];

const VOICE_RADIUS = 240;
function renderVoices(stirringSet=new Set()){
  const g = document.getElementById('voice-positions');
  g.innerHTML = '';
  VOICES.forEach((v,i)=>{
    const rad = (v.angle - 90) * Math.PI/180;
    const x = Math.cos(rad) * VOICE_RADIUS;
    const y = Math.sin(rad) * VOICE_RADIUS;
    const isStirring = stirringSet.has(v.id);

    const group = document.createElementNS(SVG_NS,'g');
    group.setAttribute('transform',`translate(${x},${y})`);
    group.setAttribute('data-voice-id', v.id);

    const plate = document.createElementNS(SVG_NS,'circle');
    plate.setAttribute('cx',0); plate.setAttribute('cy',0); plate.setAttribute('r',14);
    plate.setAttribute('fill','#02020A');
    plate.setAttribute('stroke','#8A7330');
    plate.setAttribute('stroke-width', v.state==='claimed' ? '0.8' : '0.4');
    plate.setAttribute('opacity', v.state==='claimed' ? '1' : '0.55');
    group.appendChild(plate);

    const t = document.createElementNS(SVG_NS,'text');
    t.setAttribute('x',0); t.setAttribute('y',5);
    t.setAttribute('text-anchor','middle');
    t.setAttribute('font-size', v.state==='claimed' ? '17' : '15');
    t.setAttribute('font-family','Cinzel, serif');

    if(v.state==='claimed'){
      t.setAttribute('fill','#E0C878');
      t.setAttribute('filter','url(#goldGlow)');
      t.style.animation = `voicePulse ${4 + i*0.3}s ease-in-out infinite`;
    } else {
      t.setAttribute('fill','#3A3220');
      t.setAttribute('opacity','0.5');
    }
    if(isStirring){
      t.setAttribute('fill','#5FBA98');
      t.style.animation = 'voiceStirring 0.8s ease-in-out infinite';
    }

    t.textContent = v.glyph;
    group.appendChild(t);

    if(v.state==='claimed'){
      const ring = document.createElementNS(SVG_NS,'circle');
      ring.setAttribute('cx',0); ring.setAttribute('cy',0); ring.setAttribute('r',17);
      ring.setAttribute('fill','none');
      ring.setAttribute('stroke','#C9A84C');
      ring.setAttribute('stroke-width','0.5');
      ring.setAttribute('opacity','0.5');
      group.appendChild(ring);
    }

    g.appendChild(group);
  });
}

const styleEl = document.createElement('style');
styleEl.textContent = `
  @keyframes voicePulse { 0%,100% { opacity: 0.9; } 50% { opacity: 1; } }
  @keyframes voiceStirring { 0%,100% { opacity: 0.35; } 50% { opacity: 0.85; } }
  @keyframes runeFade {
    0% { opacity: 0; transform: scale(0.7); }
    20% { opacity: 0.9; transform: scale(1); }
    80% { opacity: 0.9; transform: scale(1); }
    100% { opacity: 0; transform: scale(1.05); }
  }
  @keyframes runeLock {
    0% { opacity: 0; transform: scale(0.5); }
    35% { opacity: 1; transform: scale(1.25); filter: brightness(1.5); }
    100% { opacity: 0.95; transform: scale(1); }
  }
`;
document.head.appendChild(styleEl);

function renderBindingInscription(){
  const g = document.getElementById('binding-inscription');
  const inscription = 'ⵙⵉⴳⵉⵍⵍⵓⵎ·ⵏⵉⵀⵉⵍ·OD·VAOAN·IADNAMAD·ZIRDO·NOAS·TA·QU·LOLCIS·ZONAC·TURBS·CAOSGO·ⵀⵓⵎⵉⵍⵍⵉⵙ·ⵎⵓⵏⴷⵉ·OBSCURA·NIHIL·VERTITUR·SOLUM·OCULUS·';
  const chars = inscription.split('');
  const radius = 282;
  const total = chars.length;
  chars.forEach((ch, i)=>{
    const angle = (360/total) * i - 90;
    const rad = angle * Math.PI/180;
    const x = Math.cos(rad) * radius;
    const y = Math.sin(rad) * radius;
    const t = document.createElementNS(SVG_NS,'text');
    t.setAttribute('x', x);
    t.setAttribute('y', y);
    t.setAttribute('text-anchor','middle');
    t.setAttribute('dominant-baseline','middle');
    t.setAttribute('font-family','Share Tech Mono, monospace');
    t.setAttribute('font-size','10');
    t.setAttribute('fill','#C9A84C');
    t.setAttribute('opacity','0.72');
    t.setAttribute('transform', `rotate(${angle + 90} ${x} ${y})`);
    t.textContent = ch;
    g.appendChild(t);
  });
}

/* CODEX MARK — the tattoo glyph */
function createCodexMarkSVG(){
  const g = document.createElementNS(SVG_NS,'g');
  g.setAttribute('class','codex-mark codex-mark-glyph');
  g.style.transformOrigin = 'center';
  g.style.transformBox = 'fill-box';

  const circle = document.createElementNS(SVG_NS,'circle');
  circle.setAttribute('cx',0); circle.setAttribute('cy',0); circle.setAttribute('r',11);
  circle.setAttribute('fill','none'); circle.setAttribute('stroke','#E0C878'); circle.setAttribute('stroke-width','1.6');
  circle.setAttribute('filter','url(#goldGlow)');
  g.appendChild(circle);

  const tri = document.createElementNS(SVG_NS,'path');
  tri.setAttribute('d','M -7.5,-4 L 7.5,-4 L 0,8 Z');
  tri.setAttribute('fill','none'); tri.setAttribute('stroke','#E0C878'); tri.setAttribute('stroke-width','1.3');
  tri.setAttribute('stroke-linejoin','round');
  g.appendChild(tri);

  [[-3.2,-1.3],[3.2,-1.3],[0,3.5]].forEach(([cx,cy])=>{
    const dot = document.createElementNS(SVG_NS,'circle');
    dot.setAttribute('cx',cx); dot.setAttribute('cy',cy); dot.setAttribute('r',1.2);
    dot.setAttribute('fill','#E0C878');
    g.appendChild(dot);
  });

  return g;
}

/* RUNE RING — twelve cycling positions */
const RUNE_RADIUS = 200;
const RUNE_COUNT = 12;
const RUNE_CYCLE_MS = 2400;
const LOCK_INTERVAL = 3;
let runeIndex = 0;
let cycleCount = 0;
let lockBeatCount = 0;
let returnVisit = false;
let witnessEligible = false;

function buildRuneSlots(){
  const g = document.getElementById('rune-positions');
  g.innerHTML = '';
  for(let i=0; i<RUNE_COUNT; i++){
    const angle = (360/RUNE_COUNT) * i - 90;
    const rad = angle * Math.PI/180;
    const x = Math.cos(rad) * RUNE_RADIUS;
    const y = Math.sin(rad) * RUNE_RADIUS;

    const group = document.createElementNS(SVG_NS,'g');
    group.setAttribute('transform', `translate(${x},${y})`);
    group.setAttribute('data-slot', i);

    const t = document.createElementNS(SVG_NS,'text');
    t.setAttribute('x',0); t.setAttribute('y',7);
    t.setAttribute('text-anchor','middle');
    t.setAttribute('font-size','20');
    t.setAttribute('fill','#C9A84C');
    t.setAttribute('opacity','0.85');
    t.setAttribute('filter','url(#goldGlow)');
    t.style.transformOrigin = 'center';
    t.style.transformBox = 'fill-box';
    t.textContent = GLYPH_LIBRARY[i % GLYPH_LIBRARY.length];
    t.setAttribute('class','rune-glyph');
    group.appendChild(t);

    const mark = createCodexMarkSVG();
    mark.style.display = 'none';
    group.appendChild(mark);

    g.appendChild(group);
  }
}

/* CRITICAL FIX: use direct-children selector so we only grab the 12 slot groups,
   not the nested codex-mark <g> elements inside them */
function getRuneSlots(){
  return document.querySelectorAll('#rune-positions > g');
}

function advanceRunes(){
  cycleCount++;
  const isLockBeat = (cycleCount % LOCK_INTERVAL === 0);
  const slots = getRuneSlots();

  if(isLockBeat){
    lockBeatCount++;
    updateLockCounter();
    slots.forEach((slot, i)=>{
      const text = slot.querySelector('.rune-glyph');
      const mark = slot.querySelector('.codex-mark');
      if(!text || !mark) return;
      text.style.display = 'none';
      mark.style.display = '';
      mark.style.animation = `runeLock 0.7s ease-out`;
      setTimeout(()=>{
        mark.style.display = 'none';
        mark.style.animation = '';
        text.style.display = '';
      }, 1200);
    });
    triggerLockBeat();
  } else {
    slots.forEach((slot, i)=>{
      const t = slot.querySelector('.rune-glyph');
      if(!t) return;
      setTimeout(()=>{
        t.style.animation = '';
        runeIndex = (runeIndex + 1) % GLYPH_LIBRARY.length;
        const glyphPick = GLYPH_LIBRARY[(runeIndex + i*7) % GLYPH_LIBRARY.length];
        t.style.animation = `runeFade ${RUNE_CYCLE_MS-100}ms ease-in-out`;
        setTimeout(()=>{ t.textContent = glyphPick; }, 100);
      }, i * 60);
    });
  }
}

function triggerLockBeat(){
  const pulse = document.getElementById('lock-pulse');
  pulse.classList.add('active');
  setTimeout(()=>pulse.classList.remove('active'), 1200);
  try {
    const a = document.getElementById('audio-lock');
    if(a){ a.currentTime = 0; a.volume = 0.35; a.play().catch(()=>{}); }
  } catch(e){}
}

function updateLockCounter(){
  const el = document.getElementById('lock-counter');
  if(el) el.textContent = `LOCK_BEATS: ${lockBeatCount}`;
}

/* WADJET PUPIL — cursor tracking */
const pupilGroup = document.getElementById('pupil-group');
const sigilSvg = document.getElementById('codex-sigil');
let pupilTargetX = 0, pupilTargetY = 0;
let pupilX = 0, pupilY = 0;

function trackPupil(clientX, clientY){
  const rect = sigilSvg.getBoundingClientRect();
  const cx = rect.left + rect.width/2;
  const cy = rect.top + rect.height/2;
  const dx = clientX - cx;
  const dy = clientY - cy;
  const dist = Math.sqrt(dx*dx + dy*dy);
  const maxOffset = 5;
  const norm = Math.min(dist / (rect.width/2), 1);
  const angle = Math.atan2(dy, dx);
  pupilTargetX = Math.cos(angle) * norm * maxOffset;
  pupilTargetY = Math.sin(angle) * norm * maxOffset;
}

function pupilLoop(){
  pupilX += (pupilTargetX - pupilX) * 0.08;
  pupilY += (pupilTargetY - pupilY) * 0.08;
  pupilGroup.setAttribute('transform', `translate(${pupilX},${pupilY})`);
  requestAnimationFrame(pupilLoop);
}
pupilLoop();

/* TEARS — green Realm-III contamination */
function spawnSvgTear(anchorX, anchorY){
  const tearGroup = document.getElementById('svg-tears');
  const tear = document.createElementNS(SVG_NS,'path');
  tear.setAttribute('fill', 'url(#tearGrad)');
  tear.setAttribute('filter', 'url(#leakGlowSoft)');
  tearGroup.appendChild(tear);

  const dur = 3500 + Math.random()*1500;
  const finalLen = 95 + Math.random()*65;
  const width = 2.4 + Math.random()*0.8;
  const start = performance.now();

  function animateTear(now){
    const t = (now - start) / dur;
    if(t >= 1){
      spawnPageTear(anchorX, anchorY);
      tear.remove();
      return;
    }
    const ease = t < 0.12 ? t/0.12 : 1;
    const fade = t > 0.72 ? 1 - ((t-0.72)/0.28) : 1;
    const len = finalLen * Math.min(t*1.3, 1);
    const w = width;
    const d = `
      M ${anchorX-w/2},${anchorY}
      Q ${anchorX-w},${anchorY+len*0.5} ${anchorX-w/3},${anchorY+len}
      Q ${anchorX},${anchorY+len+w} ${anchorX+w/3},${anchorY+len}
      Q ${anchorX+w},${anchorY+len*0.5} ${anchorX+w/2},${anchorY}
      Z`;
    tear.setAttribute('d', d);
    tear.setAttribute('opacity', ease * fade);
    requestAnimationFrame(animateTear);
  }
  requestAnimationFrame(animateTear);
}

function spawnPageTear(anchorX, anchorY){
  const rect = sigilSvg.getBoundingClientRect();
  const scale = rect.width / 600;
  const screenX = rect.left + rect.width/2 + anchorX * scale;
  const screenY = rect.top + rect.height/2 + (anchorY + 95) * scale;

  const field = document.getElementById('tear-field');
  const fieldRect = field.getBoundingClientRect();
  const relX = screenX - fieldRect.left;
  const relY = screenY - fieldRect.top;

  const t = document.createElement('div');
  t.className = 'page-tear';
  t.style.left = relX + 'px';
  t.style.top = relY + 'px';
  const len = 110 + Math.random()*120;
  const dur = 3 + Math.random()*1.6;
  t.style.setProperty('--len', len + 'px');
  t.style.setProperty('--y', len + 'px');
  t.style.setProperty('--dur', dur + 's');
  field.appendChild(t);
  setTimeout(()=>t.remove(), dur * 1000 + 200);
}

function tearLoop(){
  spawnSvgTear(-89, 56);
  setTimeout(()=>spawnSvgTear(-10, 20), 600 + Math.random()*800);
  if(Math.random() < 0.45){
    setTimeout(()=>spawnSvgTear(58, 68), 1100 + Math.random()*600);
  }
  setTimeout(tearLoop, 1200 + Math.random()*900);
}

/* HOLLOW CHOIR — proximity audio */
const choir = document.getElementById('audio-choir');
let choirStarted = false;
let choirTargetVol = 0;
let choirVol = 0;

function updateChoirProximity(clientX, clientY){
  const rect = sigilSvg.getBoundingClientRect();
  const cx = rect.left + rect.width/2;
  const cy = rect.top + rect.height/2;
  const dx = clientX - cx;
  const dy = clientY - cy;
  const dist = Math.sqrt(dx*dx + dy*dy);
  const proxRange = 220;
  if(dist < proxRange){
    choirTargetVol = (1 - dist/proxRange) * 0.28;
  } else {
    choirTargetVol = 0;
  }
}

function choirLoop(){
  choirVol += (choirTargetVol - choirVol) * 0.06;
  if(choir){ choir.volume = Math.max(0, Math.min(1, choirVol)); }
  requestAnimationFrame(choirLoop);
}
choirLoop();

function startChoirOnce(){
  if(choirStarted) return;
  choirStarted = true;
  try {
    choir.volume = 0;
    choir.play().catch(()=>{ choirStarted = false; });
  } catch(e){ choirStarted = false; }
}

/* CURSOR */
const cursor = document.getElementById('cursor');
let cursorX = window.innerWidth/2, cursorY = window.innerHeight/2;
let cursorDispX = cursorX, cursorDispY = cursorY;

document.addEventListener('mousemove', (e)=>{
  cursorX = e.clientX;
  cursorY = e.clientY;
  trackPupil(e.clientX, e.clientY);
  updateChoirProximity(e.clientX, e.clientY);
  startChoirOnce();
});
document.addEventListener('click', startChoirOnce, {once:true});
document.addEventListener('touchstart', (e)=>{
  startChoirOnce();
  if(e.touches[0]){
    trackPupil(e.touches[0].clientX, e.touches[0].clientY);
    updateChoirProximity(e.touches[0].clientX, e.touches[0].clientY);
  }
}, {passive:true});

function cursorLoop(){
  cursorDispX += (cursorX - cursorDispX) * 0.25;
  cursorDispY += (cursorY - cursorDispY) * 0.25;
  cursor.style.left = cursorDispX + 'px';
  cursor.style.top = cursorDispY + 'px';
  requestAnimationFrame(cursorLoop);
}
cursorLoop();

/* RETURN-VISITOR ESCALATION */
const STORAGE_KEY = 'codex_witness_state_v1';
function loadVisitState(){
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    return raw ? JSON.parse(raw) : { visits:0, firstSeen:null, lastSeen:null, dwellMs:0, eligible:false };
  } catch(e){
    return { visits:0, firstSeen:null, lastSeen:null, dwellMs:0, eligible:false };
  }
}
function saveVisitState(s){
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(s)); } catch(e){}
}

function initVisitState(){
  const s = loadVisitState();
  const now = Date.now();
  s.visits = (s.visits || 0) + 1;
  if(!s.firstSeen) s.firstSeen = now;
  s.lastSeen = now;
  saveVisitState(s);

  returnVisit = s.visits >= 2;
  witnessEligible = s.visits >= 5 || s.dwellMs > 1000*60*5;

  applyVisitorTier(s);
}

function applyVisitorTier(s){
  const meta = document.getElementById('visit-state');
  if(witnessEligible){
    meta.textContent = `VISITOR_STATE: WITNESS_ELIGIBLE · v${s.visits}`;
    renderVoices(new Set(['voice-04','voice-11']));
  } else if(returnVisit){
    meta.textContent = `VISITOR_STATE: RETURNING · v${s.visits}`;
    renderVoices();
    setTimeout(()=>{
      const slots = getRuneSlots();
      if(slots[7]){
        const text = slots[7].querySelector('.rune-glyph');
        const mark = slots[7].querySelector('.codex-mark');
        if(text && mark){
          text.style.display = 'none';
          mark.style.display = '';
          mark.style.animation = 'runeLock 1.5s ease-out';
          setTimeout(()=>{
            mark.style.display = 'none';
            text.style.display = '';
          }, 1800);
        }
      }
    }, 500);
  } else {
    meta.textContent = `VISITOR_STATE: FIRST_CONTACT · v${s.visits}`;
    renderVoices();
  }
}

/* PREVIEW CONTROLS */
document.getElementById('btn-reset').addEventListener('click', ()=>{
  localStorage.removeItem(STORAGE_KEY);
  location.reload();
});
document.getElementById('btn-sim-return').addEventListener('click', ()=>{
  const s = loadVisitState();
  s.visits = 3;
  saveVisitState(s);
  location.reload();
});
document.getElementById('btn-sim-witness').addEventListener('click', ()=>{
  const s = loadVisitState();
  s.visits = 6;
  saveVisitState(s);
  location.reload();
});

/* BOOT */
renderBindingInscription();
buildRuneSlots();
initVisitState();

setTimeout(()=>{
  advanceRunes();
  setInterval(advanceRunes, RUNE_CYCLE_MS);
}, returnVisit ? 800 : 1400);

setTimeout(tearLoop, 800);

setInterval(()=>{
  const s = loadVisitState();
  s.dwellMs = (s.dwellMs || 0) + 5000;
  saveVisitState(s);
}, 5000);
</script>
