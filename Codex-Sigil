</div>

<div class="frame">
  <div class="sigil-vessel">
    <div class="tear-field" id="tear-field"></div>
    <svg id="codex-sigil" viewBox="-300 -300 600 600" xmlns="http://www.w3.org/2000/svg" aria-label="The Codex Sigil">
      <defs>
        <radialGradient id="goldShine" cx="0.5" cy="0.5" r="0.5">
          <stop offset="0%" stop-color="#E0C878"/>
          <stop offset="60%" stop-color="#C9A84C"/>
          <stop offset="100%" stop-color="#8A7330"/>
        </radialGradient>
        <radialGradient id="goldDeep" cx="0.5" cy="0.5" r="0.5">
          <stop offset="0%" stop-color="#C9A84C"/>
          <stop offset="100%" stop-color="#6A5424"/>
        </radialGradient>
        <radialGradient id="voidCore" cx="0.5" cy="0.5" r="0.5">
          <stop offset="0%" stop-color="#02020A"/>
          <stop offset="70%" stop-color="#05050A"/>
          <stop offset="100%" stop-color="#0A0A12"/>
        </radialGradient>
