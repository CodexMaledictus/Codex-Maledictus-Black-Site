        <radialGradient id="woundBleed" cx="0.5" cy="0.5" r="0.5">
          <stop offset="0%" stop-color="#02020A" stop-opacity="1"/>
          <stop offset="55%" stop-color="#05050A" stop-opacity="1"/>
          <stop offset="78%" stop-color="#0F2F26" stop-opacity="0.85"/>
          <stop offset="92%" stop-color="#1F5544" stop-opacity="0.55"/>
          <stop offset="100%" stop-color="#4FA88A" stop-opacity="0"/>
        </radialGradient>
        <radialGradient id="crimsonBleed" cx="0.5" cy="0.5" r="0.5">
          <stop offset="0%" stop-color="#7A1212" stop-opacity="0.5"/>
          <stop offset="60%" stop-color="#4A0808" stop-opacity="0.2"/>
          <stop offset="100%" stop-color="#7A1212" stop-opacity="0"/>
