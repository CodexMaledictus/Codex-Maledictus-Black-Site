<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>THE INNER MARGINS // INFECTION REMEMBERS</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #050505;
            --blood: #8B0000;
            --gold: #C9A84C;
            --bone: #D4D0C8;
            --scanline: rgba(255, 255, 255, 0.03);
        }

        body {
            margin: 0; background: var(--bg); color: var(--bone);
            font-family: 'Share Tech Mono', monospace; overflow-x: hidden;
        }

        /* SCANLINE OVERLAY */
        body::after {
            content: ""; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%);
            background-size: 100% 4px; z-index: 999; pointer-events: none;
        }

        .container { max-width: 900px; margin: 0 auto; padding: 40px 20px; position: relative; z-index: 10; }

        /* HEADERS & GLITCH */
        h1, h2 { font-family: 'Cinzel Decorative', cursive; text-align: center; color: var(--gold); }
        .glitch-title { font-size: 3rem; margin-bottom: 10px; position: relative; animation: slightGlitch 4s infinite; text-shadow: 0 0 10px var(--blood); }
        @keyframes slightGlitch {
            0%, 96%, 100% { transform: translate(0, 0); opacity: 1; }
            97% { transform: translate(-2px, 2px); opacity: 0.8; color: var(--blood); }
            98% { transform: translate(2px, -2px); opacity: 0.9; color: var(--bone); }
        }

        /* TABS NAVIGATION */
        .tab-nav { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; margin-bottom: 40px; border-bottom: 1px solid var(--blood); padding-bottom: 20px; }
        .tab-btn {
            background: transparent; border: 1px solid var(--gold); color: var(--gold);
            padding: 10px 15px; font-family: 'Share Tech Mono', monospace; font-size: 0.9rem;
            cursor: pointer; transition: 0.3s; text-transform: uppercase;
        }
        .tab-btn:hover, .tab-btn.active { background: var(--blood); color: var(--bone); border-color: var(--blood); box-shadow: 0 0 15px var(--blood); }

        .tab-content { display: none; min-height: 400px; border: 1px solid rgba(201, 168, 76, 0.2); padding: 30px; background: rgba(139, 0, 0, 0.05); }
        .tab-content.active { display: block; animation: fadeIn 0.5s; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        /* --- SECTION 1: RPG --- */
        .rpg-text { font-size: 1.1rem; line-height: 1.6; margin-bottom: 30px; min-height: 80px; }
        .rpg-btn { display: block; width: 100%; padding: 15px; margin-bottom: 10px; background: transparent; border: 1px solid var(--blood); color: var(--bone); font-family: inherit; cursor: pointer; text-align: left; transition: 0.2s; }
        .rpg-btn:hover { background: var(--blood); color: #000; font-weight: bold; }
        .rpg-ending { color: var(--gold); font-family: 'Cinzel Decorative', cursive; font-size: 1.5rem; text-align: center; margin-top: 20px; }

        /* --- SECTION 2: GRID --- */
        #grid-container { display: grid; grid-template-columns: repeat(25, 1fr); gap: 1px; width: 100%; aspect-ratio: 1; background: #111; border: 1px solid var(--blood); margin-bottom: 20px; }
        .cell { background: #050505; cursor: pointer; transition: background 0.2s; }
        .cell.infected { background: var(--blood); box-shadow: 0 0 5px var(--blood); }
        .cell.quarantined { background: var(--bone); }
        .grid-stats { display: flex; justify-content: space-between; color: var(--gold); font-size: 1.2rem; }
        .grid-lore { margin-top: 20px; font-style: italic; color: var(--blood); text-align: center; min-height: 50px; }

        /* --- SECTION 3: CIPHER --- */
        .cipher-box { text-align: center; }
        .cipher-text { font-size: 1.5rem; letter-spacing: 3px; color: var(--gold); margin: 30px 0; word-wrap: break-word; }
        .cipher-input { width: 80%; padding: 15px; background: transparent; border: 1px solid var(--blood); color: var(--bone); font-family: inherit; font-size: 1rem; text-align: center; outline: none; }
        .cipher-input:focus { box-shadow: 0 0 15px rgba(139, 0, 0, 0.5); }
        .cipher-reveal { margin-top: 30px; font-size: 1.2rem; color: var(--blood); display: none; animation: fadeIn 2s; }

        /* --- SECTION 4: LEDGER --- */
        .ledger-input-wrapper { display: flex; gap: 10px; margin-bottom: 30px; }
        .ledger-input { flex-grow: 1; padding: 15px; background: transparent; border: 1px solid var(--gold); color: var(--bone); font-family: inherit; font-size: 1.1rem; outline: none; }
        .ledger-btn { background: var(--gold); color: #000; border: none; padding: 0 20px; font-family: inherit; font-weight: bold; cursor: pointer; }
        .ledger-log { border-left: 2px solid var(--blood); padding-left: 15px; min-height: 200px; display: flex; flex-direction: column; gap: 15px; }
        .log-entry { margin: 0; animation: fadeIn 0.5s; }
        .log-user { color: var(--bone); opacity: 0.5; font-size: 0.8rem; }
        .log-codex { color: var(--gold); font-size: 1.1rem; margin-top: 5px; }

        /* --- SECTION 5: DOORS --- */
        .memory-board { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 30px; perspective: 1000px; }
        .card { aspect-ratio: 3/4; background: rgba(201, 168, 76, 0.1); border: 1px solid var(--gold); cursor: pointer; position: relative; transform-style: preserve-3d; transition: transform 0.5s; display: flex; align-items: center; justify-content: center; }
        .card.flipped { transform: rotateY(180deg); }
        .card.matched { border-color: var(--blood); opacity: 0.5; cursor: default; }
        .card-front, .card-back { position: absolute; width: 100%; height: 100%; backface-visibility: hidden; display: flex; align-items: center; justify-content: center; font-size: 2rem; }
        .card-front { background: var(--bg); color: transparent; }
        .card-front::after { content: "🜃"; color: var(--gold); font-size: 1.5rem; opacity: 0.3; }
        .card-back { background: var(--blood); color: var(--bone); transform: rotateY(180deg); }
        .prophecy-box { border: 1px solid var(--blood); padding: 20px; font-family: 'Cinzel Decorative', cursive; color: var(--bone); text-align: center; line-height: 1.8; }
    </style>
</head>
<body>

<div class="container">
    <h1 class="glitch-title">THE INNER MARGINS</h1>
    <p style="text-align: center; opacity: 0.6; margin-bottom: 40px; letter-spacing: 3px;">[ APOCRYPHA // INFECTION REMEMBERS ]</p>

    <div class="tab-nav">
        <button class="tab-btn active" onclick="openTab('tab-rpg', this)">The Ritual Walk</button>
        <button class="tab-btn" onclick="openTab('tab-grid', this)">The Infection Grid</button>
        <button class="tab-btn" onclick="openTab('tab-cipher', this)">The Cipher of Rot</button>
        <button class="tab-btn" onclick="openTab('tab-ledger', this)">The Confession Ledger</button>
        <button class="tab-btn" onclick="openTab('tab-doors', this)">The Thirteen Doors</button>
    </div>

    <div id="tab-rpg" class="tab-content active">
        <h2>The Ritual Walk</h2>
